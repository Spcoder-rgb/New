ORDER_COST = 30.0  # assumed fixed cost per order
EXPIRY_THRESHOLD_DAYS = 3

# Holding cost per unit per day depends on outlet rate and item unit_cost

def compute_holding_cost_daily(inv_df, items_df, outlets_df):
    enriched = inv_df.merge(items_df[['item_id','unit_cost','category']], on='item_id') \
                   .merge(outlets_df[['outlet_id','holding_cost_rate_per_day','university']], on='outlet_id')
    enriched['holding_cost_daily'] = enriched['on_hand_qty'] * enriched['unit_cost'] * enriched['holding_cost_rate_per_day']
    return enriched


def compute_eoq(sales_df, items_df, outlets_df, order_cost: float = ORDER_COST):
    # average daily demand per outlet-item
    daily_demand = sales_df.groupby(['outlet_id','item_id'], as_index=False)['quantity_sold'].mean() \
                               .rename(columns={'quantity_sold':'avg_daily_demand'})
    df = daily_demand.merge(items_df[['item_id','unit_cost','category']], on='item_id') \
                     .merge(outlets_df[['outlet_id','holding_cost_rate_per_day','university']], on='outlet_id')
    df['annual_demand'] = df['avg_daily_demand'] * 365.0
    df['holding_cost_per_unit_year'] = df['unit_cost'] * df['holding_cost_rate_per_day'] * 365.0
    # EOQ formula: sqrt(2DS/H); guard divide-by-zero
    df['EOQ'] = np.sqrt(np.maximum(0.0, 2.0 * df['annual_demand'] * order_cost) / np.maximum(1e-9, df['holding_cost_per_unit_year']))
    return df# Quick EDA snapshots
